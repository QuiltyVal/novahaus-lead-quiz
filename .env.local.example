# ============================================
# n8n Lead Collector
# ============================================
N8N_LEAD_WEBHOOK_URL=
N8N_LEAD_WEBHOOK_SECRET=

# ============================================
# AI Email Drafts
# ============================================
# template = static safe fallback
# gemini = Google Gemini
# openrouter = static OpenRouter model from AI_EMAIL_MODEL
# openrouter_auto_free = models[0].id from FREE_LLM_MODELS_URL, then FREE_LLM_FALLBACK_MODEL
AI_EMAIL_PROVIDER=template
AI_EMAIL_MODEL=openrouter/free
AI_EMAIL_TIMEOUT_MS=9000
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=NovaHaus Lead-to-Call Demo
FREE_LLM_MODELS_URL=https://shir-man.com/api/free-llm/top-models
FREE_LLM_FALLBACK_MODEL=openrouter/free

# ============================================
# Direct Customer Follow-up Email
# ============================================
# off = only save the draft text in the lead record
# send = send email directly from /api/lead, independent from n8n/Gmail
LEAD_EMAIL_MODE=off
LEAD_EMAIL_PROVIDER=resend
LEAD_EMAIL_FROM="NovaHaus Immobilien <leads@mail.valquilty.com>"
LEAD_EMAIL_REPLY_TO=leads@reply.valquilty.com
LEAD_EMAIL_BCC=
RESEND_API_KEY=
DEMO_LEAD_TARGET_EMAIL=me@valquilty.com

# ============================================
# Resend Inbound Replies
# ============================================
RESEND_INBOUND_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# Marketing trackers
# ============================================
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=YOUR_PIXEL_ID
META_ACCESS_TOKEN=YOUR_CONVERSIONS_API_ACCESS_TOKEN
META_TEST_EVENT_CODE=

# ============================================
# App
# ============================================
NEXT_PUBLIC_SITE_URL=https://leads.novahaus-demo.de
NEXT_PUBLIC_CONTACT_EMAIL=me@valquilty.com
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/valentyn-havrychenko/
