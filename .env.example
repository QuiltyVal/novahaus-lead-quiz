# ============================================
# n8n Lead Collector — Primary Lead Destination
# ============================================
# If this is set, /api/lead sends the normalized lead to n8n first.
# Google Sheets and SMTP remain fallback destinations when n8n is not configured.

N8N_LEAD_WEBHOOK_URL=https://your-n8n-instance/webhook/novahaus-lead
N8N_LEAD_WEBHOOK_SECRET=your-shared-secret

# ============================================
# AI Email Drafts — Optional
# ============================================
# Keep template in production until you have reviewed draft quality.
AI_EMAIL_PROVIDER=template
AI_EMAIL_MODEL=openrouter/free
AI_EMAIL_TIMEOUT_MS=9000
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://leads.novahaus-demo.de
OPENROUTER_APP_NAME=NovaHaus Lead-to-Call Demo
FREE_LLM_MODELS_URL=https://shir-man.com/api/free-llm/top-models
FREE_LLM_FALLBACK_MODEL=openrouter/free

# ============================================
# Google Sheets — Lead Storage
# ============================================
# 1. Go to https://console.cloud.google.com/
# 2. Create or reuse a Service Account with Google Sheets API enabled
# 3. Download the JSON key file
# 4. Copy the "client_email" and "private_key" fields below
# 5. Create a Google Sheet and share it with the Service Account email
# 6. Copy the Sheet ID from the URL: docs.google.com/spreadsheets/d/{THIS_IS_THE_ID}/edit

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=replace-with-service-account-private-key
GOOGLE_SHEET_ID=your-spreadsheet-id-here
GOOGLE_SHEET_NAME=Leads

# ============================================
# Email Notifications (optional)
# ============================================
# SMTP settings for sending lead notifications
# Works with Gmail, Outlook, or any SMTP provider
# For Gmail: use App Password (https://myaccount.google.com/apppasswords)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=marketing@novahaus-demo.de

# ============================================
# Direct Customer Follow-up Email (optional)
# ============================================
# This bypasses Gmail/n8n drafts. Keep off until DNS/provider is configured.
# Providers:
# - resend: recommended for Vercel, requires RESEND_API_KEY and verified sender domain
# - smtp: uses SMTP_HOST/SMTP_USER/SMTP_PASS above

LEAD_EMAIL_MODE=off
LEAD_EMAIL_PROVIDER=resend
LEAD_EMAIL_FROM="NovaHaus Immobilien <leads@novahaus-demo.de>"
LEAD_EMAIL_REPLY_TO=leads@reply.novahaus-demo.de
LEAD_EMAIL_BCC=
RESEND_API_KEY=your-resend-api-key
DEMO_LEAD_TARGET_EMAIL=me@valquilty.com

# ============================================
# Resend Inbound Replies (optional)
# ============================================
RESEND_INBOUND_WEBHOOK_SECRET=your-resend-webhook-signing-secret
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# Marketing trackers
# ============================================
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
META_ACCESS_TOKEN=your-capi-access-token
META_TEST_EVENT_CODE=

# ============================================
# Public contact links for /system
# ============================================
NEXT_PUBLIC_CONTACT_EMAIL=me@valquilty.com
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/valentyn-havrychenko/
